# Django core settings
DEBUG=False
SECRET_KEY=change-this-to-a-long-random-secret
ALLOWED_HOSTS=localhost,127.0.0.1,your-app.onrender.com
CSRF_TRUSTED_ORIGINS=http://127.0.0.1:8000,http://localhost:8000,https://your-app.onrender.com

# Database
# Render will provide DATABASE_URL automatically when you attach a PostgreSQL database.
DATABASE_URL=postgresql://postgres:password@host:5432/database_name
POSTGRES_SSLMODE=require
DATABASE_CONN_MAX_AGE=600

# Media storage
# For Render persistent disk deployments, point this to the mounted disk path.
DJANGO_MEDIA_ROOT=/var/data/media

# Optional static override if you want a custom build target.
DJANGO_STATIC_ROOT=staticfiles_build

# Razorpay
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

